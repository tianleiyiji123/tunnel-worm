# ====== 隧隧虫 环境配置 ======
#
# 默认使用本地磁盘存储，无需修改即可启动。
# 如需使用三方存储，取消对应区块的注释并填入真实凭证，系统会自动检测启用。

# ------ [必需] 数据库配置 ------
DB_HOST=home.superorder.cn
DB_PORT=8306
DB_USER=root
DB_PASSWORD=qwer1234
DB_NAME=suisuichong

# ------ [可选] 存储后端 ------
# 默认自动检测：有凭证就用三方存储，没有就用本地磁盘 (./uploads/)
# 如需手动指定，取消注释：STORAGE_TYPE=local / minio / alioss / tencentcos
# STORAGE_TYPE=auto
UPLOAD_DIR=./uploads

# ------ [可选] MinIO 对象存储 ------
# 取消注释并填入真实值即可启用
MINIO_ENDPOINT=http://home.superorder.cn:9000
MINIO_ACCESS_KEY=1nobIcUBiXpzLAmiCTPb
MINIO_SECRET_KEY=QIoOUAesY5R8IiYD1CDUXaGkzyPINS9OabmtWXDs
MINIO_BUCKET=suisuichong
MINIO_SECURE=false

# ------ [可选] 阿里云 OSS ------
# 填入真实值（替换 your_xxx）即可启用
# ALIOSS_ACCESS_KEY_ID=your_access_key_id
# ALIOSS_ACCESS_KEY_SECRET=your_access_key_secret
# ALIOSS_BUCKET=your_bucket_name
# ALIOSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ------ [可选] 腾讯云 COS ------
# 填入真实值（替换 your_xxx）即可启用
# TENCENTCOS_SECRET_ID=your_secret_id
# TENCENTCOS_SECRET_KEY=your_secret_key
# TENCENTCOS_BUCKET=your_bucket_name-1250000000
# TENCENTCOS_REGION=ap-guangzhou

# ------ [应用配置] ------
TRANSFER_EXPIRE_HOURS=24
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_TRANSFER=10
MAX_FAIL_ATTEMPTS=5
LOCK_DURATION_MINUTES=1

# ====== Tunnel Worm 环境配置模板 ======
#
# 使用方法: cp .env.example .env，然后根据需要取消注释并修改
#
# ---- 配置优先级 ----
# 安装向导 config.json > 环境变量 > 代码默认值
# Docker 用户: 推荐通过安装向导（Web UI）配置，无需手动编辑此文件
# 本地开发: 数据库和存储通过安装向导配置，这里只放应用运行参数

# ============================================================
# [应用参数]（可选，有默认值）
# ============================================================
# TRANSFER_EXPIRE_HOURS=24      # 资源过期时间（小时）
# MAX_FILE_SIZE_MB=50           # 单文件最大大小（MB）
# MAX_FILES_PER_TRANSFER=10     # 单次传输最大文件数
# MAX_FAIL_ATTEMPTS=5           # 密码最大错误次数
# LOCK_DURATION_MINUTES=1       # 密码错误锁定时长（分钟）
# JWT_EXPIRE_HOURS=168          # Token 有效期（小时，默认 7 天）

# ============================================================
# [数据库 & 存储]（通过安装向导配置，也可用环境变量预设）
# ============================================================
# 安装向导的配置保存在 data/config.json，优先级高于下方环境变量。
# 以下仅适用于不想用安装向导、直接通过环境变量预配置的场景。
#
# # 数据库
# DB_TYPE=sqlite                # sqlite 或 mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=suisuichong
#
# # 存储后端: local / minio / alioss / tencentcos
# STORAGE_TYPE=local
# UPLOAD_DIR=./uploads
#
# # MinIO
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=your_access_key
# MINIO_SECRET_KEY=your_secret_key
# MINIO_BUCKET=tunnelworm
# MINIO_SECURE=false
#
# # 阿里云 OSS
# ALIOSS_ACCESS_KEY_ID=your_access_key_id
# ALIOSS_ACCESS_KEY_SECRET=your_access_key_secret
# ALIOSS_BUCKET=your_bucket_name
# ALIOSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
#
# # 腾讯云 COS
# TENCENTCOS_SECRET_ID=your_secret_id
# TENCENTCOS_SECRET_KEY=your_secret_key
# TENCENTCOS_BUCKET=your_bucket_name-1250000000
# TENCENTCOS_REGION=ap-guangzhou

# ====== Tunnel Worm 环境配置模板 ======
#
# 使用方法: cp .env.example .env，然后填入你的真实配置
# 默认使用 SQLite + 本地存储，无需任何修改即可启动。
#
# Docker 用户: 大部分配置通过安装向导（Web UI）完成，无需手动编辑此文件。

# ------ [开发] 数据库配置 ------
# Docker 用户无需配置，安装向导中完成。
# 开发时如需 MySQL，取消注释并填入：
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=tunnelworm

# ------ [开发] 存储后端 ------
# 默认: 本地磁盘 (./uploads/)
# Docker: 通过安装向导选择存储后端
# UPLOAD_DIR=./uploads

# ------ [可选] MinIO 对象存储 ------
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=your_access_key
# MINIO_SECRET_KEY=your_secret_key
# MINIO_BUCKET=tunnelworm
# MINIO_SECURE=false

# ------ [可选] 阿里云 OSS ------
# ALIOSS_ACCESS_KEY_ID=your_access_key_id
# ALIOSS_ACCESS_KEY_SECRET=your_access_key_secret
# ALIOSS_BUCKET=your_bucket_name
# ALIOSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ------ [可选] 腾讯云 COS ------
# TENCENTCOS_SECRET_ID=your_secret_id
# TENCENTCOS_SECRET_KEY=your_secret_key
# TENCENTCOS_BUCKET=your_bucket_name-1250000000
# TENCENTCOS_REGION=ap-guangzhou

# ------ [应用配置] ------
# TRANSFER_EXPIRE_HOURS=24
# MAX_FILE_SIZE_MB=50
# MAX_FILES_PER_TRANSFER=10
# MAX_FAIL_ATTEMPTS=5
# LOCK_DURATION_MINUTES=1
